SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
OPENAI_API_KEY=your-openai-api-key-for-capture-json

# Optional Telegram alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional scraper tuning
PAUSE_MIN=5
PAUSE_MAX=15
FB_SESSION_DIR=./fb_session
FB_MAX_POSTS_PER_GROUP=50
FB_MAX_SCROLLS=20
# Optional: replace the default Facebook groups without editing Python.
# Prefer services/scrapers/facebook_groups.json for normal use.
# FB_GROUPS_JSON=[{"id":"123","name":"My Real Estate Group","url":"https://www.facebook.com/groups/123"}]
